generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  // runtime base is resolved automatically by the generated client
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         String    @default("EMPLOYEE")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]
  vouchers     Voucher[]
}

model Agent {
  id         String      @id @default(cuid())
  name       String
  company    String?
  email      String?
  phone      String?
  address    String?
  notes      String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  clients    Client[]
  costSheets CostSheet[]
  vouchers   Voucher[]
}

model Client {
  id          String      @id @default(cuid())
  name        String
  email       String?
  phone       String?
  nationality String?
  isResident  Boolean     @default(false)
  address     String?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  agentId     String?
  bookings    Booking[]
  agent       Agent?      @relation(fields: [agentId], references: [id])
  costSheets  CostSheet[]
  vouchers    Voucher[]
  invoices    Invoice[]
}

model Destination {
  id          String    @id @default(cuid())
  name        String
  country     String    @default("KENYA")
  description String?
  highlights  String?
  createdAt   DateTime  @default(now())
  tourDays    TourDay[]
}

model TourPackage {
  id             String     @id @default(cuid())
  title          String
  description    String?
  durationDays   Int
  durationNights Int
  countries      String     @default("[\"KENYA\"]")
  highlights     String?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  bookings       Booking[]
  rateCards      RateCard[]
  days           TourDay[]
}

model TourDay {
  id            String       @id @default(cuid())
  tourPackageId String
  destinationId String?
  dayNumber     Int
  title         String
  description   String?
  accommodation String?
  mealPlan      String?
  activities    String?
  createdAt     DateTime     @default(now())
  destination   Destination? @relation(fields: [destinationId], references: [id])
  tourPackage   TourPackage  @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)
}

model RateCard {
  id            String      @id @default(cuid())
  tourPackageId String
  season        String      @default("LOW")
  validFrom     DateTime
  validTo       DateTime
  basedOn2      Float
  basedOn4      Float
  basedOn6      Float
  basedOn8      Float
  basedOn10     Float?
  basedOn12     Float?
  markupPercent Float       @default(10)
  currency      String      @default("USD")
  includes      String?
  excludes      String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tourPackage   TourPackage @relation(fields: [tourPackageId], references: [id], onDelete: Cascade)
}

model Property {
  id          String    @id @default(cuid())
  name        String
  type        String    @default("CAMP")
  location    String?
  country     String    @default("KENYA")
  category    Int       @default(3)
  contactName String?
  phone       String?
  email       String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vouchers    Voucher[]
}

model Vehicle {
  id          String    @id @default(cuid())
  name        String
  type        String    @default("OPEN_SIDED_JEEP")
  seats       Int
  regPlate    String?
  isAvailable Boolean   @default(true)
  ratePerDay  Float?
  currency    String    @default("KES")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vouchers    Voucher[]
}

model Booking {
  id                  String       @id @default(cuid())
  bookingRef          String       @unique
  clientId            String
  tourPackageId       String?
  assignedToId        String?
  status              String       @default("ENQUIRY")
  startDate           DateTime
  endDate             DateTime
  numAdults           Int          @default(1)
  numChildren         Int          @default(0)
  isResident          Boolean      @default(false)
  totalAmount         Float?
  currency            String       @default("USD")
  paidAmount          Float        @default(0)
  notes               String?
  specialRequirements String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  assignedTo          User?        @relation(fields: [assignedToId], references: [id])
  client              Client       @relation(fields: [clientId], references: [id])
  tourPackage         TourPackage? @relation(fields: [tourPackageId], references: [id])
  costSheets          CostSheet[]
  invoices            Invoice[]
  itinerary           Itinerary?
  vouchers            Voucher[]
}

model Itinerary {
  id        String         @id @default(cuid())
  bookingId String?  @unique           // 👈 add this
  title     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  booking   Booking?       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  days      ItineraryDay[]
  embeds    ItineraryEmbed[]
}

model ItineraryDay {
  id            String           @id @default(cuid())
  itineraryId   String
  dayNumber     Int
  date          DateTime?
  destination   String
  accommodation String?
  mealPlan      String?
  activities    String?
  notes         String?
  createdAt     DateTime         @default(now())
  itinerary     Itinerary        @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  images        ItineraryImage[]
}

model ItineraryImage {
  id        String        @id @default(cuid())
  dayId     String?
  filename  String
  mimeType  String
  data      String
  caption   String?
  createdAt DateTime      @default(now())
  day       ItineraryDay? @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model Voucher {
  id             String    @id @default(cuid())
  voucherNo      String    @unique
  type           String    @default("HOTEL")
  bookingId      String?
  propertyId     String?
  hotelName      String?
  vehicleId      String?
  createdById    String
  roomType       String?
  checkIn        DateTime?
  checkOut       DateTime?
  numNights      Int?
  numAdults      Int?
  numChildren    Int?
  numTwins       Int?
  numDoubles     Int?
  numSingles     Int?
  numTriples     Int?
  clientName     String?
  remarks        String?
  vehicleName    String?
  vehicleType    String?
  pickupDate     DateTime?
  dropoffDate    DateTime?
  pickupLocation String?
  route          String?
  rateKES        Float?
  flightName     String?
  flightSchedule String?
  departureDate  DateTime?
  returnDate     DateTime?
  numDays        Int?
  bookingStatus  String    @default("book")
  status         String    @default("ACTIVE")
  notes          String?
  issuedDate     DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  agentId        String?
  clientId       String?
  agent          Agent?    @relation(fields: [agentId], references: [id])
  booking        Booking?  @relation(fields: [bookingId], references: [id])
  client         Client?   @relation(fields: [clientId], references: [id])
  createdBy      User      @relation(fields: [createdById], references: [id])
  property       Property? @relation(fields: [propertyId], references: [id])
  vehicle        Vehicle?  @relation(fields: [vehicleId], references: [id])
}

model Invoice {
  id                  String    @id @default(cuid())
  invoiceNo           String    @unique
  bookingId           String?
  clientId            String?
  costSheetId         String?
  billTo              String
  billToEmail         String?
  billToPhone         String?
  invoiceDate         DateTime  @default(now())
  dueDate             DateTime
  lineItems           String
  subtotal            Float
  taxAmount           Float     @default(0)
  depositReceived     Float     @default(0)
  totalAmount         Float
  amountPaid          Float     @default(0)
  currency            String    @default("KES")
  paymentInstructions String?
  notes               String?
  status              String    @default("DRAFT")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  booking             Booking?  @relation(fields: [bookingId], references: [id])
  client              Client?   @relation(fields: [clientId], references: [id])
  costSheet           CostSheet? @relation(fields: [costSheetId], references: [id])
}

model CostSheet {
  id                String   @id @default(cuid())
  bookingRef        String?
  tourTitle         String
  days              Int
  numPax            Int
  extras            String?
  fileHandlingFee   Float    @default(0)
  ecoBottle         Float    @default(0)
  evacInsurance     Float    @default(0)
  subtotal          Float
  markupPercent     Float    @default(10)
  markupAmount      Float
  totalCost         Float
  currency          String   @default("USD")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  agentId           String?
  arrivalTransfer   Float    @default(0)
  boardBasis        String   @default("FB")
  bookingId         String?
  clientId          String?
  dayRows           String   @default("[]")
  departureTransfer Float    @default(0)
  flightCostPP      Float    @default(0)
  maasaiCost        Float    @default(0)
  maasaiVillage     Boolean  @default(false)
  numAdults         Int      @default(1)
  numChildren       Int      @default(0)
  perAdultCost      Float
  perChildCost      Float    @default(0)
  isOutdated        Boolean  @default(false)
  agent             Agent?   @relation(fields: [agentId], references: [id])
  booking           Booking? @relation(fields: [bookingId], references: [id])
  client            Client?  @relation(fields: [clientId], references: [id])
  invoices          Invoice[]
}

model SRCounty {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  region    String?
  createdAt DateTime  @default(now())
  hotels    SRHotel[]

  @@map("sr_counties")
}

model SRHotel {
  id           Int          @id @default(autoincrement())
  countyId     Int
  name         String
  stars        Int?
  category     String?
  contactEmail String?
  contactPhone String?
  notes        String?
  createdAt    DateTime     @default(now())
  county       SRCounty     @relation(fields: [countyId], references: [id])
  roomTypes    SRRoomType[]
  seasons      SRSeason[]

  @@unique([countyId, name])
  @@map("sr_hotels")
}

model SRRoomType {
  id           Int           @id @default(autoincrement())
  hotelId      Int
  name         String
  description  String?
  maxOccupancy Int           @default(2)
  createdAt    DateTime      @default(now())
  prices       SRRoomPrice[]
  hotel        SRHotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, name])
  @@map("sr_room_types")
}

model SRSeason {
  id        Int           @id @default(autoincrement())
  hotelId   Int
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime      @default(now())
  prices    SRRoomPrice[]
  hotel     SRHotel       @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("sr_seasons")
}

model SRRoomPrice {
  id                   Int        @id @default(autoincrement())
  roomTypeId           Int
  seasonId             Int
  boardBasis           String     @default("FB")
  ratePerPersonSharing Float?
  singleRoomRate       Float?
  childRate            Float?
  currency             String     @default("USD")
  notes                String?
  updatedAt            DateTime   @updatedAt
  thirdAdultRate       Float?     @map("third_adult_rate")
  roomType             SRRoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  season               SRSeason   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, seasonId, boardBasis])
  @@map("sr_room_prices")
}

model Log {
  id        String   @id @default(cuid())
  level     String   @default("INFO")
  message   String
  context   String?
  userId    String?
  userEmail String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model AgentRun {
  id        String   @id @default(cuid())
  origin    String   // dashboard that started it
  prompt    String
  status    String   @default("running") // running | done | error
  summary   String?
  steps     Int      @default(0)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  AgentMessage[]
}

model AgentMessage {
  id        String   @id @default(cuid())
  runId     String
  agent     String   // orchestrator | cost-sheet | itinerary | invoice | rate-intel | itinerary-gen | monitor | ui
  kind      String   // system | user | handoff | tool | assistant | audit | error
  content   String
  payload   Json?
  createdAt DateTime @default(now())

  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
}

model ItineraryEmbed {
  id          String    @id @default(cuid())
  token       String    @unique
  label       String    @default("Public")
  itineraryId String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  visits      Int       @default(0)
  itinerary   Itinerary? @relation(fields: [itineraryId], references: [id], onDelete: Cascade)

  @@index([token])
}
