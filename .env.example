# ─── Supabase PostgreSQL ───────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → Database

# "Transaction" connection string (used by Prisma at runtime via connection pooler)
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# "Session" connection string (used by prisma db push / migrate / seed)
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-this-to-a-long-random-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"



# ─── Owner ───────────────────────────────────────────────────────────────────
OWNER_EMAIL="irayaian15@gmail.com"
NEXT_PUBLIC_OWNER_EMAIL="irayaian15@gmail.com"
ADMIN_SECRET_TOKEN="fMv6i77L57vGl7HYFp2BlsYkr41zL+Jp+8VxJK1NipE="

# ─── Logging ─────────────────────────────────────────────────────────────────
# Options: debug | info | warn | error (default: info in prod, debug in dev)
LOG_LEVEL="info"

# ─── Email notifications (Resend) ────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="SafariOps <noreply@yourdomain.com>"

# ─── WhatsApp notifications (Twilio) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
OWNER_WHATSAPP="+254700000000"

# ─── SMTP (used by lib/agents/notify.ts + voucher sending) ───────────────────
# Previously hardcoded in app/api/vouchers/[id]/send/route.ts — move that
# route over to these env vars too when you get a chance.
SMTP_HOST="mail.yourdomain.com"
SMTP_PORT="465"
SMTP_USER="marketing@jaetravel.co.ke"
SMTP_PASS="change-me"

# ─── NVIDIA NIM (LLM backend for AI agents) ──────────────────────────────────
NVIDIA_API_KEY="nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NVIDIA_MODEL="nvidia/llama-3.3-nemotron-super-49b-v1.5"
